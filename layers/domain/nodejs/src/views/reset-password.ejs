<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Email Verification</title>
</head>

<body style="
      margin: 0;
      padding: 0;
      background-color: #F1F5F9;
      font-family: Arial, Helvetica, sans-serif;
      color: black;
">
    <!-- BEGIN CONTAINER -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0"
        style="background-color: #F1F5F9; padding: 1.5rem 0;">
        <tr>
            <td align="center">
                <!-- BEGIN CONTENT -->
                <table width="600" cellpadding="0" cellspacing="0" border="0"
                    style="background-color: white; border-radius: 0.5rem; overflow: hidden;">
                    <!-- BEGIN HEADER -->
                    <%- include("partials/email-header"), { text: "Reset your password" } %>
                        <!-- END HEADER -->

                        <!-- BEGIN BODY -->
                        <tr>
                            <td
                                style="background-color: #EEF2FF; padding: 1.5rem; font-size: 1rem; line-height: 1.5rem;">
                                <p style="margin-bottom: 1rem;">
                                    Hello <%= firstName %>,
                                </p>

                                <p style="margin-bottom: 1rem;">
                                    We received a request to reset the password for your account.
                                    To continue, please verify this request by clicking the button
                                    below.
                                </p>

                                <!-- BEGIN BUTTON -->
                                <table cellpadding="0" cellspacing="0" border="0" align="center"
                                    style="margin: 1.5rem auto;">
                                    <tr>
                                        <td align="center" style="
                                        background-color: #4f46e5; /* tailwind indigo-600 */
                                        border-radius: 4px;
                                    ">
                                            <a href="<%= url %>" target="_blank" style="
                                            display: inline-block;
                                            padding: 0.5rem 1.5rem;
                                            font-size: 14px;
                                            font-weight: bold;
                                            color: white;
                                            text-decoration: none;
                                        ">
                                                Verify & Reset Password
                                            </a>
                                        </td>
                                    </tr>
                                </table>
                                <!-- END BUTTON -->

                                <p style="margin-bottom: 1rem;">
                                    This link will expire in 1 hour for security reasons. If you did
                                    not request a password reset, you can safely ignore this email
                                    and your password will remain unchanged.
                                </p>
                                <p style="margin: 0;">
                                    Thanks,<br />
                                    - The Team at TypeCrafters.
                                </p>
                            </td>
                        </tr>
                        <!-- END BODY -->

                        <!-- BEGIN FOOTER -->
                        <%- include("partials/email-footer") %>
                            <!-- END FOOTER -->

                </table>
                <!-- END CONTENT -->
            </td>
        </tr>
    </table>
    <!-- END CONTAINER -->
</body>
</html>