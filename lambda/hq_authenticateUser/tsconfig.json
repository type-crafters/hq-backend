{
    "include": ["src/**/*.ts"],
    "compilerOptions": {
        "strict": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": false,
        "outDir": "dist",
        "verbatimModuleSyntax": true,
        "removeComments": true,
        "sourceMap": false,
        "esModuleInterop": true,
        "target": "esnext"
    },
    "exclude": ["node_modules", "dist", "test"]
}