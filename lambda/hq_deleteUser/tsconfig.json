{
    "compilerOptions": {
        "strict": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": false,
        "types": ["node", "aws-lambda"],
        "outDir": "dist",
        "removeComments": true,
        "verbatimModuleSyntax": true,
        "sourceMap": false,
        "esModuleInterop": true,
        "target": "esnext",
        "skipLibCheck": true
    },
    "exclude": ["node_modules", "dist", "test"]
}